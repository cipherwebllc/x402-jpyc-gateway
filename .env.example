# OpenPay の discovery に登録する、クエリなしの完全な API URL
MY_RESOURCE_URL=https://your-gateway.example.com/api/consult

# coo-icp (default) または http
ADAPTER=coo-icp

# ADAPTER=coo-icp のとき必須
COO_CANISTER_ID=
IC_HOST=https://icp-api.io
# 強く推奨: ランダムな秘密値。未設定 (匿名 identity) だと coo-icp 側の会話履歴が
# 匿名 principal として誰からでも読めてしまう
IC_IDENTITY_SEED=

# ADAPTER=http のとき必須
UPSTREAM_URL=
